PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
SERVE_FRONTEND=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Blender is required for local generation, mesh repair, previews, STL and PLY exports.
BLENDER_BIN=blender

# Assimp is used for mesh-to-mesh conversion when available.
ASSIMP_BIN=assimp

# Optional CAD/BREP conversion backends.
# FreeCAD can create STEP/IGES/DXF approximations from repaired mesh output.
FREECAD_CMD=FreeCADCmd

# Proprietary/vendor formats need licensed tools. Templates support:
# {input} {output} {format} {jobDir}
PARASOLID_CONVERTER_CMD=
SOLIDWORKS_CONVERTER_CMD=
DWG_CONVERTER_CMD=

STORAGE_ROOT=
